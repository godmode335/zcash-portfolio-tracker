---
import { downloadUrl } from "../lib/seo";
interface Props { label?: string }
const { label = "Download for Windows" } = Astro.props;
const href = downloadUrl();
---
<a class="download-btn" href={href} rel="noopener" download data-testid="download">
  {label}
  <span class="dl-sub">Free · Windows 10/11 · private</span>
</a>
