---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) =>
    b.data.date.getTime() - a.data.date.getTime() ||
    a.data.title.localeCompare(b.data.title));

const title = "Privacy Coin Guides & Comparisons | Privacy Coin Tracker Blog";
const description = "Guides on tracking Zcash, Monero and other privacy coins, comparisons, and how to stay private.";
---
<BaseLayout title={title} description={description} path="/blog">
  <h1>Blog</h1>
  <ul>
    {posts.map((p) => (
      <li>
        <a href={`/blog/${p.id}`}>{p.data.title}</a>
        <div class="muted">{p.data.description}</div>
      </li>
    ))}
  </ul>
</BaseLayout>
