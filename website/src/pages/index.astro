---
import BaseLayout from "../layouts/BaseLayout.astro";
import DownloadButton from "../components/DownloadButton.astro";
import { softwareAppJsonLd, faqJsonLd, organizationJsonLd, webSiteJsonLd } from "../lib/seo";

const title = "Zcash Portfolio Tracker — Private ZEC Tracker for Windows";
const description =
  "Track your Zcash (ZEC) holdings, cost basis and P&L privately on Windows. Local-first, no account, no cloud. Free download.";

const features = [
  { h: "Privacy by design", p: "Your ZEC holdings never leave your PC. Only public price requests go out." },
  { h: "Zcash focus", p: "Built specifically for Zcash (ZEC) — not buried in a list of thousands of tokens." },
  { h: "Real P&L", p: "Transaction-based cost basis with realized and unrealized profit/loss for ZEC." },
  { h: "Charts & portfolios", p: "Portfolio value history and ZEC price charts. Multiple portfolios supported." },
  { h: "No account", p: "No sign-up, no email, no KYC. Open it and start tracking your ZEC." },
  { h: "Free & lightweight", p: "~3 MB installer. Windows 10/11. WebView2 already included." },
];

const faqs = [
  { q: "Is Zcash Portfolio Tracker free?", a: "Yes, it is completely free to download and use." },
  { q: "Does it send my ZEC portfolio anywhere?", a: "No. All data stays in a local database on your PC. Only public ZEC prices are fetched." },
  { q: "Which coin is supported?", a: "Zcash (ZEC) — the leading privacy-preserving cryptocurrency." },
  { q: "Do I need an account?", a: "No account, email or KYC is required." },
  { q: "Which OS does it run on?", a: "Windows 10 and Windows 11 (64-bit)." },
];
---
<BaseLayout title={title} description={description} path="/" jsonLd={[organizationJsonLd(), webSiteJsonLd(), softwareAppJsonLd(), faqJsonLd(faqs)]}>
  <section class="hero">
    <span class="eyebrow">Local-first · Open source</span>
    <h1>Track your Zcash privately</h1>
    <p class="lead">A local-first Windows portfolio tracker for Zcash (ZEC). No account. No cloud. Your data stays on your PC.</p>
    <p><DownloadButton /></p>
    <div class="trust">
      <span>No account</span>
      <span>100% local</span>
      <span>Open source</span>
      <span>~3 MB · Windows 10/11</span>
    </div>
    <figure class="shot">
      <img src="/screenshots/dashboard.png" width="1393" height="720"
        alt="Zcash Portfolio Tracker dashboard: ZEC holdings with value, profit and loss, and a portfolio value chart"
        loading="eager" decoding="async" />
    </figure>
  </section>

  <section>
    <h2>Why Zcash Portfolio Tracker</h2>
    <div class="features">
      {features.map((f) => (
        <div class="card"><h3>{f.h}</h3><p class="muted">{f.p}</p></div>
      ))}
    </div>
  </section>

  <section>
    <h2>Frequently asked questions</h2>
    <dl class="faq">
      {faqs.map((f) => (<><dt>{f.q}</dt><dd class="muted">{f.a}</dd></>))}
    </dl>
  </section>

  <section class="hero">
    <h2>Start tracking your ZEC privately</h2>
    <p><DownloadButton label="Download free for Windows" /></p>
  </section>
</BaseLayout>
